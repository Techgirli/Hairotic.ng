# Primary Database (Neon PostgreSQL local fallback)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hairotic?schema=public"

# Cache and Session Store (Upstash Redis local fallback)
REDIS_URL="redis://localhost:6379"

# JSON Web Token Secret Keys
JWT_ACCESS_SECRET="your_short_lived_access_secret_at_least_32_chars_long"
JWT_REFRESH_SECRET="your_long_lived_refresh_secret_at_least_32_chars_long"

# Payment Processor (Paystack)
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_WEBHOOK_SECRET="whsec_..."

# Media Delivery CDN (Cloudinary)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# Transactional Email Service (Resend)
RESEND_API_KEY="re_..."

# Messaging Integration (Meta WhatsApp Cloud API)
WHATSAPP_CLOUD_API_TOKEN="EAAG..."

# Error Monitoring (Sentry)
SENTRY_DSN="https://..."

# Public-facing app URL — used in email links (verify email, password reset)
# Set to your production domain in deployment
APP_URL="http://localhost:3000"

# Shared secret for the payment reconciliation cron endpoint
# Generate with: openssl rand -hex 32
# Must also be set as a GitHub Actions secret (RECONCILE_SECRET) in your repo
RECONCILE_SECRET="generate_a_strong_random_secret_here"

# Runtime environment
NODE_ENV="development"
