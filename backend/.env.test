# Backend environment variables for CI test runs.
# All DB calls are mocked in unit tests — this value is just needed
# so Prisma client generation does not error on import.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hairotic"
JWT_ACCESS_SECRET="ci_test_access_secret_key_for_jest"
JWT_REFRESH_SECRET="ci_test_refresh_secret_key_for_jest"
NODE_ENV="test"
