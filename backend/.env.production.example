# ============================================================
# Hairotic.ng Backend — Production Environment Template
# Copy this file to .env.production and fill in real values.
# NEVER commit this file with real secrets to source control.
# ============================================================

# --- Database (Neon PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
DATABASE_URL="postgresql://postgres:REPLACE_ME@REPLACE_ME_HOST:5432/hairotic?sslmode=require"

# --- JWT Secrets (generate with: openssl rand -hex 64) ---
JWT_ACCESS_SECRET="REPLACE_ME_WITH_STRONG_RANDOM_SECRET"
JWT_REFRESH_SECRET="REPLACE_ME_WITH_STRONG_RANDOM_SECRET"

# --- Payment: Paystack ---
PAYSTACK_SECRET_KEY="sk_live_REPLACE_ME"

# --- Email: Resend ---
RESEND_API_KEY="re_REPLACE_ME"

# --- Application ---
PORT=3001
NODE_ENV=production
